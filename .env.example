# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/atlas_synapse?sslmode=require"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# Edge → Web HMAC (generate: openssl rand -hex 32)
INGEST_WORKER_SECRET="replace_with_32_byte_hex_secret"

# Edge worker target (production: your Vercel URL)
WEB_INGEST_URL="http://localhost:3000/api/ingest"

# LLM (Anthropic) — used in Phase 3+
ANTHROPIC_API_KEY="sk-ant-..."

# Email (Resend) — used in Phase 5+
RESEND_API_KEY="re_..."
