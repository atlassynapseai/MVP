generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id       String   @id @default(cuid())
  ownerId  String   @unique  // Supabase auth user UUID of the workspace owner
  name     String
  createdAt DateTime @default(now())

  users        User[]
  connections  Connection[]
  agents       Agent[]
  traces       Trace[]
  incidents    Incident[]
  alertPrefs   AlertPref[]
  webhooks     Webhook[]
  auditLogs    AuditLog[]
}

model User {
  id             String   @id @default(cuid())
  supabaseUserId String   @unique  // Supabase auth user UUID
  email          String   @unique
  createdAt      DateTime @default(now())

  orgId  String
  org    Organization @relation(fields: [orgId], references: [id])

  feedbacks    Feedback[]
}

enum ConnectionType {
  zapier
  oauth
  builder
}

enum ConnectionStatus {
  active
  revoked
}

model Connection {
  id                String           @id @default(cuid())
  type              ConnectionType
  projectTokenHash  String           @unique
  providerMeta      Json?
  status            ConnectionStatus @default(active)
  revokedAt         DateTime?
  createdAt         DateTime         @default(now())

  orgId  String
  org    Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

model Agent {
  id           String    @id @default(cuid())
  externalId   String
  displayName  String
  platform     String?
  lastSeenAt   DateTime?
  createdAt    DateTime  @default(now())

  orgId  String
  org    Organization @relation(fields: [orgId], references: [id])

  traces     Trace[]
  incidents  Incident[]
  alertPrefs AlertPref[]

  @@unique([orgId, externalId])
}

enum TraceStatus {
  received
  processing
  pass
  evaluated
  translated
  alerted
  failed
}

model Trace {
  id                  String      @id @default(cuid())
  externalTraceId     String
  timestamp           DateTime
  redactedPrompt      String
  redactedResponse    String
  toolCalls           Json        @default("[]")
  tokenCount          Int?
  costMicroUsd        Int?
  rawRedactedPayload  Json
  summary             String?
  status              TraceStatus @default(received)
  redactionVersion    String      @default("v1")
  statusUpdatedAt     DateTime    @default(now())
  evaluationAttempts  Int         @default(0)
  nextEvaluationAt    DateTime?
  createdAt           DateTime    @default(now())

  orgId    String
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  agentId  String
  agent    Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)

  evaluation  Evaluation?
  incident    Incident?

  @@unique([agentId, externalTraceId])
  @@index([orgId, agentId, timestamp(sort: Desc)])
  @@index([status, nextEvaluationAt])
}

model Evaluation {
  id              String   @id @default(cuid())
  // Legacy field — keep for backwards compat, derived from outcome
  pass            Boolean
  // New structured fields
  outcome         String   // "pass" | "anomaly" | "failure"
  category        String?  // IncidentCategory value; null when outcome=pass
  confidence      Float    // 0.0–1.0, enforced at app layer
  // Legacy reason field — kept for P2, deprecated in P3
  reason          String
  // New business-language fields
  businessImpact  String?  // plain-English impact for non-technical operators
  technicalReason String   // detailed reason for debugging
  model           String
  createdAt       DateTime @default(now())

  traceId  String @unique
  trace    Trace  @relation(fields: [traceId], references: [id], onDelete: Cascade)
}

enum IncidentSeverity {
  warning
  critical
}

model Incident {
  id          String           @id @default(cuid())
  severity    IncidentSeverity
  category    String           // IncidentCategory value
  summary     String           // incidentSummary from IncidentRendering
  dedupKey    String
  createdAt   DateTime         @default(now())
  resolvedAt  DateTime?        // null = open, set = resolved
  resolvedBy  String?          // supabaseUserId of resolver

  traceId  String @unique
  trace    Trace  @relation(fields: [traceId], references: [id], onDelete: Cascade)
  agentId  String
  agent    Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  orgId    String
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  alerts    Alert[]
  feedbacks Feedback[]

  @@index([orgId, createdAt(sort: Desc)])
  @@index([dedupKey])
}

enum AlertChannel {
  email
}

enum AlertStatus {
  sent
  failed
}

model Alert {
  id         String       @id @default(cuid())
  channel    AlertChannel
  sentAt     DateTime
  status     AlertStatus

  incidentId  String
  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
}

model Feedback {
  id               String   @id @default(cuid())
  correct          Boolean
  correctCategory  String?  // IncidentCategory value the user thinks it actually was
  correctSeverity  String?  // "warning" | "critical" | "none"
  note             String?
  createdAt        DateTime @default(now())

  incidentId  String
  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AlertMode {
  immediate
  digest
  off
}

model AlertPref {
  id                String           @id @default(cuid())
  mode              AlertMode        @default(immediate)
  severityFloor     IncidentSeverity @default(warning)
  slackWebhookUrl   String?          // optional Slack incoming webhook URL
  customEvalCriteria String?         // org-defined extra eval rules (plain text, ≤1000 chars)

  orgId    String
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  agentId  String?
  agent    Agent?       @relation(fields: [agentId], references: [id])

  @@unique([orgId, agentId])
}

model Webhook {
  id        String   @id @default(cuid())
  url       String
  secret    String   // HMAC-SHA256 signing secret
  events    String[] // ["incident.created", "incident.resolved"]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  orgId  String
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // e.g. "incident.resolved", "alert_pref.updated"
  details   Json     @default("{}")
  createdAt DateTime @default(now())

  orgId   String
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId  String?      // null for system actions
  agentId String?
}
