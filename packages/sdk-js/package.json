{
  "name": "@atlas/sdk-js",
  "version": "0.2.0",
  "description": "AtlasSynapse JavaScript/TypeScript SDK — trace AI agents from Node.js, Vercel AI SDK, and more",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
