# Slack Demo Bot — Environment Variables
# Copy to .env and fill in all values before running.

# ── Slack ────────────────────────────────────────────────────────────────────
# Bot Token: OAuth & Permissions → install to workspace → copy xoxb-...
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App Token: Socket Mode → enable → generate token with connections:write scope → copy xapp-...
SLACK_APP_TOKEN=xapp-your-app-token

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key

# ── Atlas Synapse ────────────────────────────────────────────────────────────
# Your project token from the Connections page in the Atlas Synapse dashboard
ATLAS_PROJECT_TOKEN=your-32-char-project-token

# Edge worker ingest URL (production Cloudflare worker)
ATLAS_INGEST_URL=https://atlas-synapse-edge.atlassynapseai.workers.dev

# Your deployed Vercel app URL — used to trigger immediate evaluation after each trace
# Leave blank to skip (evaluation will run at 2am UTC cron instead)
ATLAS_APP_URL=https://your-app.vercel.app

# Cron secret from your Vercel env — required for ATLAS_APP_URL to work
CRON_SECRET=your-cron-secret
